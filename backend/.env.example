# ============================================================
# TalentSol ATS — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ------ Database ------
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/talentsol_ats

# ------ Server ------
PORT=3001
NODE_ENV=development

# ------ JWT Auth ------
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# ------ CORS ------
CORS_ORIGIN=http://localhost:5173

# ------ App URL (used for invite links, Stripe redirects) ------
APP_URL=http://localhost:5173

# ------ File Upload ------
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# ------ Rate Limiting ------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ------ Stripe Billing (optional — billing routes return 503 without this) ------
# Create products + prices at https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ------ Email (optional — invites/verification logged to console without this) ------
# Resend: https://resend.com (recommended) or any SMTP provider
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=TalentSol

# ------ Redis Cache (optional — falls back to in-memory without this) ------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CLUSTER_ENABLED=false
CACHE_TTL_DEFAULT=1800
CACHE_TTL_QUERY=1800
CACHE_TTL_SESSION=86400
CACHE_TTL_AI_ANALYSIS=7200

# ------ File Storage (optional — Cloudflare R2, post-MVP) ------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=talentsol-uploads
R2_PUBLIC_URL=
